# Job Tracker 生产环境配置
# 放置于服务器 /opt/job-tracker/.env
# 
# 注意：此文件包含敏感信息，切勿提交到 Git！
# 所有变量也可以通过 GitHub Secrets 配置，由 CI/CD 自动注入

# ==================== 数据库配置 ====================
PG_USER=postgres
PG_PASSWORD=your_secure_postgres_password

# ==================== JWT 配置 ====================
JWT_SECRET=your-secure-jwt-secret-min-32-chars

# ==================== GitHub OAuth ====================
# 从 https://github.com/settings/developers 获取
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://jobs.ninesun.site/api/login/githubCallBack
CLIENT_URL=https://jobs.ninesun.site

# ==================== OCR 服务 ====================
OCR_PROVIDER=qwen
LLM_API_URL=https://coding.dashscope.aliyuncs.com/v1/chat/completions
LLM_API_KEY=your_llm_api_key
LLM_MODEL=qwen-vl-plus

# ==================== Docker Hub ====================
DOCKER_USERNAME=ninesun6666
