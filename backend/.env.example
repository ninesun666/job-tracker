# 面试投递记录平台配置

# 服务端口
PORT=3001

# ==================== OCR 服务配置 ====================
# OCR 提供商: glm | claude | openai (不设置则自动检测)
OCR_PROVIDER=glm

# GLM (智谱 AI) - 推荐，国内访问稳定
# 注册地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4v-flash

# Claude (Anthropic)
# 注册地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI / 兼容 API
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o

# ==================== 公司信息查询 ====================
# 企查查 API Key
QCC_API_KEY=

# 天眼查 API Key
TIANYANCHA_API_KEY=
