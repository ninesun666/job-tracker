{
  "name": "job-tracker-backend",
  "version": "1.0.0",
  "description": "面试投递记录平台后端",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --testTimeout=10000 --forceExit",
    "test:e2e": "jest tests/e2e.test.js --testTimeout=15000 --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["routes/*.js", "services/*.js"],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2"
  }
}
